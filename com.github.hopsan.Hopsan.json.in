{
    "app-id": "com.github.hopsan.Hopsan",
    "runtime": "org.kde.Platform",
    "runtime-version": "5.15-24.08",
    "sdk": "org.kde.Sdk",
    "command": "hopsangui",
    "build-options" : {
        "env": {
            "TERM": "xterm"
        }
    },
    "finish-args": [
        "--device=dri",
        "--socket=fallback-x11",
        "--share=ipc",
        "--share=network",
        "--filesystem=home",
        "--socket=wayland"
    ],
    "modules": [
        {
            "name": "hopsan",
            "disabled": false,
            "buildsystem": "simple",
            "build-commands": [
                "./packaging/prepareSourceCode.sh $(pwd) $(pwd) HOPSAN_BASE_VERSION HOPSAN_RELEASE_REVISION HOPSAN_FULL_RELEASE_VERSION HOPSAN_DEVELOPMENT_RELEASE false",

                "cd dependencies; ./setupAsio.sh",
                "cd dependencies; ./setupDiscount.sh",
                "cd dependencies; ./setupFmi4c.sh",
                "cd dependencies; ./setupHDF5.sh",
                "cd dependencies; ./setupKatex.sh",
                "cd dependencies; ./setupZeroMQ.sh",
                "cd dependencies; ./setupMsgpack.sh",
                "cd dependencies; ./setupTclap.sh",
                "cd dependencies; ./setupQwt.sh",
                "cd dependencies; ./setupXerces.sh",
                "cd dependencies; ./setupLibzip.sh",
                "cd dependencies; ./setupDCPLib.sh",
                "cd dependencies; ./setupSsp4c.sh",

                "qmake HopsanNG.pro",
                "make -j$(nproc)",

                "./packaging/copyInstallHopsan.sh $(pwd) /app"
            ],
            "post-install": [
                "install -t /app/share/icons/hicolor/128x128/apps/ -Dm644 com.github.hopsan.Hopsan.png",
                "install -t /app/share/applications/ -Dm644 com.github.hopsan.Hopsan.desktop",
                "install -t /app/share/metainfo/ -Dm644 com.github.hopsan.Hopsan.appdata.xml"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/Hopsan/hopsan.git",
                    "tag": "vHOPSAN_BASE_VERSION",
                    "commit": "HOPSAN_COMMIT_HASH"
                },
                {"type": "file", "sha256": "4ea6cc8782c6508b3051c469ed7a1b6ca20b023c2a0c26ccd9c83bc7e61dfc16", "url": "https://github.com/Orc/discount/archive/refs/tags/v3.0.1.2.tar.gz", "dest-filename": "discount-v3.0.1.2.tar.gz", "dest": "dependencies", "mirror-urls": []},
                {"type": "file", "sha256": "e4defbac30f50d64e1556374aa49e574417c9e72c6b1de7a4ff88c4b1bea6e9b", "url": "https://support.hdfgroup.org/releases/hdf5/v1_14/v1_14_6/downloads/hdf5-1.14.6.tar.gz", "dest-filename": "hdf5-1.14.6.tar.gz", "dest": "dependencies", "mirror-urls": []},
                {"type": "file", "sha256": "9fd44a2e93cb1abb819c258b35c725cba54e5123c8420799b6a40a6a76ccf89e", "url": "https://github.com/KaTeX/KaTeX/releases/download/v0.12.0/katex.tar.gz", "dest-filename": "katex.tar.gz", "dest": "dependencies", "mirror-urls": []},
                {"type": "file", "sha256": "8592d12e19ac3796889b8358bc8f78df9272e6aa7a9ea1834bafd68e4073549a", "url": "https://github.com/msgpack/msgpack-c/releases/download/cpp-3.1.1/msgpack-3.1.1.tar.gz", "dest-filename": "msgpack-c-msgpack-3.1.1.tar.gz", "dest": "dependencies", "mirror-urls": []},
                {"type": "file", "sha256": "dcb085896c28aaec5518cbc08c0ee2b4e60ada7ac929d82639f6189851a6129a", "url": "https://downloads.sourceforge.net/project/qwt/qwt/6.3.0/qwt-6.3.0.tar.bz2", "dest-filename": "qwt-6.3.0.tar.bz2", "dest": "dependencies", "mirror-urls": []},
                {"type": "file", "sha256": "9f9f0fe3719e8a89d79b6ca30cf2d16620fba3db5b9610f9b51dd2cd033deebb", "url": "https://downloads.sourceforge.net/project/tclap/tclap-1.2.1.tar.gz", "dest-filename": "tclap-1.2.1.tar.gz", "dest": "dependencies", "mirror-urls": []},
                {"type": "file", "sha256": "6653ef5910f17954861fe72332e68b03ca6e4d9c7160eb3a8de5a5a913bfab43", "url": "https://github.com/zeromq/libzmq/releases/download/v4.3.5/zeromq-4.3.5.tar.gz", "dest-filename": "zeromq-4.3.5.tar.gz", "dest": "dependencies", "mirror-urls": []},
                {"type": "file", "sha256": "0fff4ff311a7c88fdb76fceefba0e180232d56984f577db371d505e4d4c91afd", "url": "https://github.com/zeromq/cppzmq/archive/refs/tags/v4.11.0.tar.gz", "dest-filename": "cppzmq-v4.11.0.tar.gz", "dest": "dependencies", "mirror-urls": []},
                {"type": "file", "sha256": "fef563b29470c1a2341c81278a514218297c760f862469f9bf83cbffcdb354da", "url": "https://master.dl.sourceforge.net/project/asio/asio/1.12.1%20%28Stable%29/asio-1.12.1.zip", "dest-filename": "asio-1.12.1.zip", "dest": "dependencies", "mirror-urls": []},
                {"type": "file", "sha256": "47b90cc64241d1cf854aa488c9ba7f6a33b27449946246ac50b10e6ce7e366af", "url": "https://github.com/apache/xerces-c/archive/53c0401812bfe5523594c1180f5ac7c758a2eaf7.zip", "dest-filename": "xerces-53c0401812bfe5523594c1180f5ac7c758a2eaf7.zip", "dest": "dependencies", "mirror-urls": []},
                {"type": "file", "sha256": "8a247f57d1e3e6f6d11413b12a6f28a9d388de110adc0ec608d893180ed7097b", "url": "https://github.com/nih-at/libzip/releases/download/v1.11.4/libzip-1.11.4.tar.xz", "dest-filename": "libzip-1.11.4.tar.xz", "dest": "dependencies", "mirror-urls": []},
                {"type": "file", "sha256": "553b26515e4dc586b75d0b0c607c99b1e54ea8cda7ab89375c02fd1ee83f2c2d", "url": "https://github.com/modelica/DCPLib/archive/359d16b.zip", "dest-filename": "dcplib-359d16b.zip", "dest": "dependencies", "mirror-urls": []},
                {"type": "file", "sha256": "aa709d0e2c77a499336a9adaf0b118967964a3bd11a666cde00447c47aee35d4", "url": "https://github.com/robbr48/fmi4c/archive/4a77c6a971750be6b70b7d52f7ee492d0f901819.zip", "dest-filename": "fmi4c-4a77c6a971750be6b70b7d52f7ee492d0f901819.zip", "dest": "dependencies", "mirror-urls": []},
                {"type": "file", "sha256": "a97a4f8d11226151c66f66d94ba2a3c1fb84a2d20d2a6ac24117faf98bbf030f", "url": "https://github.com/peterNordin/ssp4c/archive/72339ea2955a6c44ab058193723b8fc260bfd56e.zip", "dest-filename": "ssp4c-72339ea2955a6c44ab058193723b8fc260bfd56e.zip", "dest": "dependencies", "mirror-urls": []},
                {
                    "type": "file",
                    "path": "com.github.hopsan.Hopsan.png"
                },
                {
                    "type": "file",
                    "path": "com.github.hopsan.Hopsan.desktop"
                },
                {
                    "type": "file",
                    "path": "com.github.hopsan.Hopsan.appdata.xml"
                }
            ]
        }
    ]
}
